# Copy to .env and fill in. .env is git-ignored.
#
# Browser-visible vars (anything with VITE_ prefix is inlined into the
# client bundle by Vite — never put secrets here).
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# Server-only vars (used by /api/* serverless routes — NO VITE_ prefix,
# so Vite cannot leak them into the client bundle). Set these in Vercel
# project settings, not in this file.
# SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Server-only pepper for the spam-triage IP hash. Without this, the
# /api/* routes will store ip_hash as NULL rather than a weak unsalted
# hash. Generate with: openssl rand -hex 32
# IP_HASH_PEPPER=your-random-pepper
