# Copy to .env and fill in. .env is git-ignored.
#
# Browser-visible vars (anything with VITE_ prefix is inlined into the
# client bundle by Vite — never put secrets here).
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# Server-only vars (used by /api/* serverless routes — NO VITE_ prefix,
# so Vite cannot leak them into the client bundle). Set these in Vercel
# project settings, not in this file.
# SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Server-only pepper for the spam-triage IP hash. Without this, the
# /api/* routes will store ip_hash as NULL rather than a weak unsalted
# hash. Generate with: openssl rand -hex 32
# IP_HASH_PEPPER=your-random-pepper

# Upstash Redis for rate-limiting on /api/*. Free tier covers ~10K
# req/day. Sign up at https://console.upstash.com/redis and create a
# Redis DB; copy the REST URL and REST token.
#
# Fail behaviour when unset:
#   - VERCEL_ENV=production: routes return 503 (fail-closed)
#   - any other env: rate-limit becomes a no-op with a console.warn
# UPSTASH_REDIS_REST_URL=https://<your-db>.upstash.io
# UPSTASH_REDIS_REST_TOKEN=<your-rest-token>

# Revolut Merchant API. Live secret key from Revolut Business →
# Settings → APIs → Merchant API → Production API Secret key (Generate).
# Sandbox uses sk_sandbox_… and REVOLUT_API_BASE=https://sandbox-merchant.revolut.com/api
# REVOLUT_API_KEY=sk_xxxxx
# REVOLUT_API_BASE=https://merchant.revolut.com/api
# REVOLUT_API_VERSION=2024-09-01

# Resend transactional email. https://resend.com/api-keys
# RESEND_FROM must be a verified-domain address in production;
# 'onboarding@resend.dev' works while you're testing.
# RESEND_API_KEY=re_xxxxx
# RESEND_FROM=ÉIRVOX <receipts@your-domain.ie>
